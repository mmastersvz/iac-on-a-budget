# OCI Object Storage — S3-compatible Terraform backend
# Generated by: bash bootstrap/state/init-backend.sh
# Copy to backend.hcl and fill in values (never commit backend.hcl)

bucket   = "tf-state-oracle-k3s"
key      = "terraform.tfstate"
region   = "us-ashburn-1"
endpoint = "https://<namespace>.compat.objectstorage.us-ashburn-1.oraclecloud.com"

skip_region_validation      = true
skip_credentials_validation = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
force_path_style            = true

# OCI Customer Secret Key (Profile → Customer Secret Keys in OCI Console)
# Different from the API key used by the provider
access_key = "<customer_secret_key_id>"
secret_key  = "<customer_secret_key>"
